<!-- Floating Chatbot Widget -->
<div id="chatbot-widget">
    <!-- Toggle Button with Pulse Animation -->
    <button id="chatbot-toggle" class="chatbot-toggle" aria-label="Chat with us" title="Chat with Catron Assistant">
        <i class="fas fa-comments"></i>
        <span class="pulse-ring"></span>
        <span class="pulse-ring-2"></span>
        <span class="notification-badge" id="notification-badge">1</span>
    </button>

    <!-- Chatbot Container -->
    <div id="chatbot-container" class="chatbot-container">
        <!-- Header -->
        <div class="chatbot-header">
            <div class="header-left">
                <div class="bot-avatar-header">
                    <i class="fas fa-robot"></i>
                    <span class="status-dot"></span>
                </div>
                <div class="bot-info">
                    <h4>Catron AI Assistant</h4>
                    <p class="status-text">
                        <i class="fas fa-circle"></i> Powered by AI
                    </p>
                </div>
            </div>
            <div class="header-actions">
                <button id="minimize-btn" class="header-btn" title="Minimize">
                    <i class="fas fa-minus"></i>
                </button>
                <button id="close-btn" class="header-btn" title="Close">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>

        <!-- Messages Area -->
        <div id="chatbot-messages" class="chatbot-messages">
            <div class="welcome-message">
                <div class="bot-avatar-msg">
                    <i class="fas fa-robot"></i>
                </div>
                <div class="message-bubble bot-bubble">
                    <p>Hello! 👋 I'm your AI-powered assistant. Ask me anything about our products, services, or how I can help you today!</p>
                    <span class="message-time">Just now</span>
                </div>
            </div>
        </div>

        <!-- Quick Replies -->
        <div class="quick-replies" id="quick-replies">
            <button class="quick-reply" data-message="What laptops do you have?">
                <i class="fas fa-laptop"></i> Laptops
            </button>
            <button class="quick-reply" data-message="How can I track my order?">
                <i class="fas fa-box"></i> Track Order
            </button>
            <button class="quick-reply" data-message="What are your prices?">
                <i class="fas fa-tag"></i> Pricing
            </button>
            <button class="quick-reply" data-message="Do you offer delivery?">
                <i class="fas fa-truck"></i> Delivery
            </button>
        </div>

        <!-- Typing Indicator -->
        <div class="typing-indicator" id="typing-indicator" style="display: none;">
            <div class="typing-dots">
                <span></span>
                <span></span>
                <span></span>
            </div>
            <span class="typing-text">AI is thinking...</span>
        </div>

        <!-- Input Area -->
        <div class="chatbot-input">
            <button class="input-btn" id="emoji-btn" title="Quick actions">
                <i class="fas fa-smile"></i>
            </button>
            <input type="text"
                   id="chat-input"
                   placeholder="Ask me anything..."
                   autocomplete="off"
                   maxlength="500" />
            <button class="input-btn send-btn" id="send-btn" title="Send message">
                <i class="fas fa-paper-plane"></i>
            </button>
        </div>

        <!-- Powered By Footer -->
        <div class="chatbot-footer">
            <small>🤖 Powered by AI | Catron Technology 2026</small>
        </div>
    </div>
</div>
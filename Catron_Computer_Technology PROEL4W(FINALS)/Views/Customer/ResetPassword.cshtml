@using Catron_Computer_Technology_PROEL4W_FINALS_.Models.ViewModels
@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

@section Styles {
    <link href="/css/auth-customer.css" rel="stylesheet" />
}

<div class="c-auth-page">
    <div class="c-orb c-orb-1"></div>
    <div class="c-orb c-orb-2"></div>
    <div class="c-orb c-orb-3"></div>

    <div class="c-auth-card">

        <a href="/Customer/Login" class="c-brand">
            <span class="c-brand-icon"><i class="fas fa-microchip"></i></span>
            <span class="c-brand-name">Catron Computer Technology</span>
        </a>

        <div class="c-logo"><i class="fas fa-key"></i></div>

        <h1 class="c-title">Set New Password</h1>
        <p class="c-subtitle">Enter and confirm your new password below.</p>

        <form asp-action="ResetPassword" method="post" novalidate>
            <input type="hidden" asp-for="Token" />
            <input type="hidden" asp-for="Email" />

            <div asp-validation-summary="ModelOnly" class="c-errors"></div>

            <!-- New Password -->
            <div class="c-field">
                <div class="c-label-row">
                    <label class="c-label" asp-for="NewPassword">New Password</label>
                </div>
                <div class="c-input-wrap">
                    <i class="fas fa-lock c-ico"></i>
                    <input asp-for="NewPassword" type="password" id="newPwd"
                           class="c-input c-has-eye" placeholder="Minimum 6 characters"
                           autocomplete="new-password" />
                    <button type="button" class="c-eye" id="newPwdEye" aria-label="Toggle">
                        <i class="fas fa-eye" id="newPwdIcon"></i>
                    </button>
                </div>
                <!-- Strength bar -->
                <div class="c-strength">
                    <div class="c-strength-track">
                        <div class="c-strength-fill" id="rStrengthFill" data-level="0"></div>
                    </div>
                    <span class="c-strength-hint" id="rStrengthHint">Enter a password</span>
                </div>
                <span asp-validation-for="NewPassword" class="c-err"></span>
            </div>

            <!-- Confirm Password -->
            <div class="c-field">
                <div class="c-label-row">
                    <label class="c-label" asp-for="ConfirmPassword">Confirm New Password</label>
                </div>
                <div class="c-input-wrap">
                    <i class="fas fa-lock c-ico"></i>
                    <input asp-for="ConfirmPassword" type="password" id="confirmPwd"
                           class="c-input c-has-eye" placeholder="Repeat your new password"
                           autocomplete="new-password" />
                    <button type="button" class="c-eye" id="confirmPwdEye" aria-label="Toggle">
                        <i class="fas fa-eye" id="confirmPwdIcon"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="c-err"></span>
            </div>

            <button type="submit" class="c-btn">
                <i class="fas fa-shield-alt me-2"></i>Reset My Password
            </button>
        </form>

        <div class="c-divider">or</div>
        <p class="c-footer-text">
            <a href="/Customer/Login"><i class="fas fa-arrow-left me-1"></i>Back to Login</a>
        </p>

    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';
            function eyeToggle(inputId, btnId, iconId) {
                var inp = document.getElementById(inputId);
                var btn = document.getElementById(btnId);
                var ico = document.getElementById(iconId);
                if (!btn) return;
                btn.addEventListener('click', function () {
                    var show = inp.type === 'password';
                    inp.type = show ? 'text' : 'password';
                    ico.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
                });
            }
            eyeToggle('newPwd',     'newPwdEye',     'newPwdIcon');
            eyeToggle('confirmPwd', 'confirmPwdEye', 'confirmPwdIcon');

            var pwdInput = document.getElementById('newPwd');
            var fill     = document.getElementById('rStrengthFill');
            var hint     = document.getElementById('rStrengthHint');
            var hints    = ['', 'Too short', 'Weak', 'Fair', 'Good', 'Strong!'];
            if (pwdInput && fill) {
                pwdInput.addEventListener('input', function () {
                    var v = pwdInput.value, score = 0;
                    if (v.length >= 6)           score++;
                    if (v.length >= 10)          score++;
                    if (/[A-Z]/.test(v))         score++;
                    if (/[0-9]/.test(v))         score++;
                    if (/[^A-Za-z0-9]/.test(v))  score++;
                    fill.setAttribute('data-level', v.length ? score : 0);
                    hint.textContent = v.length ? hints[score] : 'Enter a password';
                });
            }
            var conf = document.getElementById('confirmPwd');
            if (conf && pwdInput) {
                conf.addEventListener('blur', function () {
                    conf.classList.remove('valid', 'invalid');
                    if (conf.value) conf.classList.add(conf.value === pwdInput.value ? 'valid' : 'invalid');
                });
            }
        })();
    </script>
}


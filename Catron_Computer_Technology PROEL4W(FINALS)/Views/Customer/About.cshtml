@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <div class="row align-items-center g-5 mb-5">
        <div class="col-lg-6">
            <h1 class="fw-bold mb-3">About <span class="text-primary">Catron</span><br />Computer Technology</h1>
            <p class="text-muted lead">We are Cebu's trusted computer technology partner, delivering quality products and exceptional service since 2010.</p>
            <p class="text-muted">From laptops to desktops, peripherals to software — we carry everything a student, professional, or gamer needs. All products are 100% genuine with warranty.</p>
            <div class="row g-3 mt-2">
                <div class="col-6"><div class="about-stat"><div class="about-stat-num text-primary">10K+</div><div class="small text-muted">Happy Customers</div></div></div>
                <div class="col-6"><div class="about-stat"><div class="about-stat-num text-warning">500+</div><div class="small text-muted">Products Available</div></div></div>
                <div class="col-6"><div class="about-stat"><div class="about-stat-num text-success">15+</div><div class="small text-muted">Years Experience</div></div></div>
                <div class="col-6"><div class="about-stat"><div class="about-stat-num text-danger">4.9★</div><div class="small text-muted">Customer Rating</div></div></div>
            </div>
        </div>
        <div class="col-lg-6 text-center">
            <div class="about-visual bg-primary bg-opacity-10 rounded-4 p-5">
                <i class="fas fa-store text-primary" style="font-size:8rem; opacity:.4"></i>
                <h5 class="mt-3 text-primary fw-bold">Catron Computer Technology</h5>
                <p class="text-muted small mb-0">Cebu City, Philippines</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <i class="fas fa-shield-alt text-primary fs-2 mb-3"></i>
                <h5 class="fw-bold">Our Mission</h5>
                <p class="text-muted small">To provide affordable, genuine technology products that empower every Filipino to achieve more.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <i class="fas fa-eye text-warning fs-2 mb-3"></i>
                <h5 class="fw-bold">Our Vision</h5>
                <p class="text-muted small">To be the most trusted computer technology provider in the Visayas region by 2030.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100 text-center p-4">
                <i class="fas fa-heart text-danger fs-2 mb-3"></i>
                <h5 class="fw-bold">Our Values</h5>
                <p class="text-muted small">Integrity, customer-first mindset, innovation, and passion for technology drive everything we do.</p>
            </div>
        </div>
    </div>
</div>

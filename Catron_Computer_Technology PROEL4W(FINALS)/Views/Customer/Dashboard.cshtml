@using Catron_Computer_Technology_PROEL4W_FINALS_.Models.ViewModels
@model AccountDashboardViewModel
@{
    ViewData["Title"] = "My Account";
}

@functions { string StatusColor(OrderStatus s) => s switch { OrderStatus.ToPay => "warning", OrderStatus.ToShip => "info", OrderStatus.ToReceive => "primary", OrderStatus.ToReview => "success", OrderStatus.Completed => "success", OrderStatus.ReturnRefund => "secondary", OrderStatus.Cancelled => "danger", _ => "secondary" }; }

<div class="container py-4">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">@await Html.PartialAsync("_AccountSidebar", Model.Customer, new ViewDataDictionary(ViewData) { { "Active", "dashboard" } })</div>

        <div class="col-lg-9">
            <div class="card border-0 shadow-sm rounded-4 mb-4 bg-primary text-white overflow-hidden">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h4 class="fw-bold mb-1">Hello, @Model.Customer.FirstName! 👋</h4>
                        <p class="mb-0 opacity-75">Welcome back to your Catron account.</p>
                    </div>
                    <i class="fas fa-user-circle" style="font-size:5rem;opacity:.2"></i>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 d-flex justify-content-between align-items-center pt-4 px-4">
                    <h5 class="fw-bold mb-0">Recent Orders</h5>
                    <a href="/Customer/MyOrders" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-4">
                    @if (!Model.RecentOrders.Any())
                                        {
                    <div class="text-center py-4">
                        <i class="fas fa-shopping-bag fs-1 text-muted mb-3"></i>
                        <p class="text-muted">No orders yet.</p>
                        <a href="/Customer/Products" class="btn btn-primary btn-sm">Shop Now</a>
                    </div>
                                        }
                                        else
                                        {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light"><tr><th>Order #</th><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th></th></tr></thead>
                            <tbody>
                                @foreach (var o in Model.RecentOrders)
                                                                {
                                <tr>
                                    <td><strong>#@o.OrderNumber</strong></td>
                                    <td class="small text-muted">@o.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>@o.OrderItems.Count item(s)</td>
                                    <td>₱@o.TotalAmount.ToString("N0")</td>
                                    <td><span class="badge bg-@StatusColor(o.Status)">@o.Status</span></td>
                                    <td><a href="/Customer/OrderDetail/@o.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                                </tr>
                                                                }
                            </tbody>
                        </table>
                    </div>
                                        }
                </div>
            </div>
        </div>
    </div>
</div>

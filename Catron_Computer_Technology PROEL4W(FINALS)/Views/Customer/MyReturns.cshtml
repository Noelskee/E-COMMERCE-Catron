@model IEnumerable<ReturnRequest>
@{
    ViewData["Title"] = "Returns & Cancellations";
}

@functions {
    string ReturnColor(ReturnStatus s) => s switch
    {
        ReturnStatus.Pending => "warning",
        ReturnStatus.Approved => "success",
        ReturnStatus.Rejected => "danger",
        ReturnStatus.Completed => "info",
        _ => "secondary"
    };
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-3">
            @await Html.PartialAsync("_AccountSidebar", null as Customer,
            new ViewDataDictionary(ViewData) { { "Active", "returns" } })
        </div>
        <div class="col-lg-9">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-3">
                    <h5 class="fw-bold mb-0">
                        <i class="fas fa-undo text-secondary me-2"></i>My Returns &amp; Cancellations
                        <span class="badge bg-secondary ms-2">@Model.Count()</span>
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (!Model.Any())
                    {
                        <div class="text-center py-5">
                            <i class="fas fa-undo fs-1 text-muted mb-3 d-block"></i>
                            <h6 class="text-muted">No return requests yet.</h6>
                        </div>
                    }
                    else
                    {
                        @foreach (var r in Model)
                        {
                            <div class="border rounded-3 p-4 mb-3">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h6 class="fw-bold mb-1">Order #@r.Order?.OrderNumber</h6>
                                        <small class="text-muted">Requested: @r.RequestedAt.ToString("MMM dd, yyyy h:mm tt")</small>
                                    </div>
                                    <span class="badge bg-@ReturnColor(r.Status) px-3 py-2">@r.Status</span>
                                </div>

                                <div class="mb-2">
                                    <span class="fw-semibold small text-muted">Reason:</span>
                                    <p class="mb-0 small">@r.Reason</p>
                                </div>

                                @if (!string.IsNullOrEmpty(r.AdminNote))
                                {
                                    <div class="alert alert-info rounded-3 mb-0 mt-2 py-2 px-3 small">
                                        <i class="fas fa-info-circle me-2"></i>
                                        <strong>Admin Note:</strong> @r.AdminNote
                                    </div>
                                }

                                @if (r.ResolvedAt.HasValue)
                                {
                                    <div class="text-muted small mt-2">
                                        <i class="fas fa-check me-1"></i>Resolved: @r.ResolvedAt.Value.ToString("MMM dd, yyyy")
                                    </div>
                                }

                                <div class="mt-3">
                                    <a href="/Customer/OrderDetail/@r.OrderId" class="btn btn-sm btn-outline-primary">
                                        <i class="fas fa-eye me-1"></i>View Order
                                    </a>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</div>

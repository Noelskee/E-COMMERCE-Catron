@using Catron_Computer_Technology_PROEL4W_FINALS_.Models.ViewModels
@model ManageAccountViewModel
@{
    ViewData["Title"] = "Manage My Account";
}

@functions {
    string StatusColor(OrderStatus s) => s switch
    {
        OrderStatus.ToPay => "warning",
        OrderStatus.ToShip => "info",
        OrderStatus.ToReceive => "primary",
        OrderStatus.ToReview => "success",
        OrderStatus.Completed => "success",
        OrderStatus.ReturnRefund => "secondary",
        OrderStatus.Cancelled => "danger",
        _ => "secondary"
    };
}

<div class="container py-4">
    <div class="row g-4">

        <!-- Sidebar -->
        <div class="col-lg-3">
            @await Html.PartialAsync("_AccountSidebar", Model.Customer,
            new ViewDataDictionary(ViewData) { { "Active", "manage" } })
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">

            <!-- ── Personal Profile ─────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold"><i class="fas fa-user text-primary me-2"></i>Personal Profile</h5>
                </div>
                <div class="card-body p-4">
                    <form asp-action="UpdateProfile" method="post">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">First Name</label>
                                <input name="FirstName" class="form-control" value="@Model.Customer.FirstName" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Last Name</label>
                                <input name="LastName" class="form-control" value="@Model.Customer.LastName" required />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Email Address</label>
                                <input class="form-control bg-light" value="@Model.Customer.Email" readonly />
                                <small class="text-muted">Email cannot be changed.</small>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Phone Number</label>
                                <input name="PhoneNumber" class="form-control" value="@Model.Customer.PhoneNumber" placeholder="+63 9XX XXX XXXX" />
                            </div>
                            <div class="col-12">
                                <button type="submit" class="btn btn-primary px-4 fw-semibold">
                                    <i class="fas fa-save me-2"></i>Save Changes
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>

            <!-- ── Saved Addresses ──────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold"><i class="fas fa-map-marker-alt text-danger me-2"></i>My Addresses</h5>
                    <button class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                        <i class="fas fa-plus me-1"></i>Add Address
                    </button>
                </div>
                <div class="card-body p-4">
                    @if (!Model.Addresses.Any())
                    {
                        <div class="text-center py-3" style="color:#64748b">
                            <i class="fas fa-map-marker-alt" style="font-size:2rem;display:block;margin-bottom:.5rem;opacity:.4"></i>
                            <p class="mb-0" style="font-size:.9rem">No saved addresses yet. Click <strong>+ Add Address</strong> to add one.</p>
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var addr in Model.Addresses)
                            {
                                <div class="col-md-6">
                                    <div style="border:1.5px solid @(addr.IsDefault ? "#22c55e" : "#e2e8f0");border-radius:12px;padding:1rem;background:#fff;height:100%">
                                        <!-- Badges row -->
                                        <div style="display:flex;gap:.4rem;flex-wrap:wrap;margin-bottom:.6rem;min-height:1.4rem">
                                            @if (addr.IsDefault)
                                            {
                                                <span style="display:inline-flex;align-items:center;gap:.25rem;font-size:.68rem;font-weight:800;color:#16a34a;background:rgba(22,163,74,.1);border:1px solid rgba(22,163,74,.25);border-radius:100px;padding:.18rem .6rem">
                                                    <i class="fas fa-star" style="font-size:.55rem"></i> Default Shipping
                                                </span>
                                            }
                                            @if (addr.IsBillingDefault)
                                            {
                                                <span style="display:inline-flex;align-items:center;gap:.25rem;font-size:.68rem;font-weight:800;color:#d97706;background:rgba(217,119,6,.1);border:1px solid rgba(217,119,6,.25);border-radius:100px;padding:.18rem .6rem">
                                                    <i class="fas fa-file-invoice" style="font-size:.55rem"></i> Default Billing
                                                </span>
                                            }
                                        </div>
                                        <!-- Address details -->
                                        <p style="font-weight:700;font-size:.9rem;color:#0f172a;margin-bottom:.25rem">@addr.FullName</p>
                                        <p style="font-size:.82rem;color:#475569;margin-bottom:.2rem;line-height:1.45">@addr.Address</p>
                                        <p style="font-size:.8rem;color:#64748b;margin-bottom:.75rem">@addr.PhoneNumber</p>
                                        <form asp-action="DeleteAddress" method="post" style="display:inline">
                                            <input type="hidden" name="id" value="@addr.Id" />
                                            <button type="submit" style="padding:.3rem .75rem;border-radius:7px;border:1.5px solid rgba(220,38,38,.3);background:rgba(220,38,38,.06);color:#dc2626;font-size:.78rem;font-weight:700;cursor:pointer"
                                                    onclick="return confirm('Remove this address?')">
                                                <i class="fas fa-trash-alt" style="margin-right:.3rem"></i>Remove
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- ── Default Billing Address ──────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold"><i class="fas fa-file-invoice text-warning me-2"></i>Default Billing Address</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.DefaultBillingAddress != null)
                    {
                        <p class="fw-semibold mb-1">@Model.DefaultBillingAddress.FullName</p>
                        <p class="text-muted mb-1">@Model.DefaultBillingAddress.Address</p>
                        <p class="text-muted mb-0">@Model.DefaultBillingAddress.PhoneNumber</p>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No billing address set. Add an address and mark it as billing default.</p>
                    }
                </div>
            </div>

            <!-- ── Recent Orders ────────────────────────────────── -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 px-4 pb-0 d-flex justify-content-between align-items-center">
                    <h5 class="fw-bold"><i class="fas fa-box-open text-success me-2"></i>Recent Orders</h5>
                    <a href="/Customer/MyOrders" class="btn btn-sm btn-outline-primary">View All</a>
                </div>
                <div class="card-body p-4">
                    @if (!Model.RecentOrders.Any())
                    {
                        <p class="text-muted text-center py-3">No orders yet. <a href="/Customer/Products">Start shopping!</a></p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr><th>Order #</th><th>Date</th><th>Items</th><th>Total</th><th>Status</th><th></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var o in Model.RecentOrders)
                                    {
                                        <tr>
                                            <td><strong>#@o.OrderNumber</strong></td>
                                            <td class="small text-muted">@o.CreatedAt.ToString("MMM dd, yyyy")</td>
                                            <td>@o.OrderItems.Count item(s)</td>
                                            <td class="fw-semibold">₱@o.TotalAmount.ToString("N0")</td>
                                            <td><span class="badge bg-@StatusColor(o.Status)">@o.Status</span></td>
                                            <td><a href="/Customer/OrderDetail/@o.Id" class="btn btn-sm btn-outline-primary">View</a></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>

<!-- Add Address Modal -->
<div class="modal fade" id="addAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content rounded-4 border-0">
            <div class="modal-header border-0 px-4 pt-4">
                <h5 class="modal-title fw-bold"><i class="fas fa-plus text-primary me-2"></i>Add New Address</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="AddAddress" method="post">
                <div class="modal-body px-4">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Full Name</label>
                            <input name="FullName" class="form-control" placeholder="Juan dela Cruz" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Complete Address</label>
                            <textarea name="Address" class="form-control" rows="3"
                                      placeholder="House No., Street, Barangay, City, Province, ZIP" required></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold small">Phone Number</label>
                            <input name="PhoneNumber" class="form-control" placeholder="+63 9XX XXX XXXX" required />
                        </div>
                        <div class="col-6">
                            <div class="form-check">
                                <input name="IsDefault" value="true" type="checkbox" class="form-check-input" id="isDefault" />
                                <label class="form-check-label small" for="isDefault">Set as default shipping</label>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-check">
                                <input name="IsBillingDefault" value="true" type="checkbox" class="form-check-input" id="isBilling" />
                                <label class="form-check-label small" for="isBilling">Set as billing default</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0 px-4 pb-4">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary fw-semibold"><i class="fas fa-save me-2"></i>Save Address</button>
                </div>
            </form>
        </div>
    </div>
</div>

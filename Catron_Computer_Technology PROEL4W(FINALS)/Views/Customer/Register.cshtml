@using Catron_Computer_Technology_PROEL4W_FINALS_.Models.ViewModels
@model CustomerRegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

@section Styles {
    <link href="/css/AuthCustomer.css" rel="stylesheet" />
}

<div class="c-auth-page">
    <div class="c-orb c-orb-1"></div>
    <div class="c-orb c-orb-2"></div>
    <div class="c-orb c-orb-3"></div>

    <div class="c-auth-card c-auth-card--wide">

        <a href="/Customer/Index" class="c-brand">
            <span class="c-brand-icon"><i class="fas fa-microchip"></i></span>
            <span class="c-brand-name">Catron Computer Technology</span>
        </a>

        <div class="c-logo"><i class="fas fa-user-plus"></i></div>

        <h1 class="c-title">Create Account</h1>
        <p class="c-subtitle">Join thousands of shoppers at Catron</p>

        <!-- Feature perks -->
        <div class="c-perks">
            <span class="c-perk"><i class="fas fa-tag"></i> Exclusive deals</span>
            <span class="c-perk"><i class="fas fa-truck"></i> Track orders</span>
            <span class="c-perk"><i class="fas fa-heart"></i> Wishlist</span>
            <span class="c-perk"><i class="fas fa-shield-alt"></i> Secure checkout</span>
        </div>

        <form asp-action="Register" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="c-errors"></div>

            <!-- Name row -->
            <div class="c-row">
                <div class="c-field">
                    <div class="c-label-row">
                        <label class="c-label" asp-for="FirstName">First Name</label>
                    </div>
                    <div class="c-input-wrap">
                        <i class="fas fa-user c-ico"></i>
                        <input asp-for="FirstName" class="c-input" placeholder="Juan" autocomplete="given-name" />
                    </div>
                    <span asp-validation-for="FirstName" class="c-err"></span>
                </div>
                <div class="c-field">
                    <div class="c-label-row">
                        <label class="c-label" asp-for="LastName">Last Name</label>
                    </div>
                    <div class="c-input-wrap">
                        <i class="fas fa-user c-ico"></i>
                        <input asp-for="LastName" class="c-input" placeholder="dela Cruz" autocomplete="family-name" />
                    </div>
                    <span asp-validation-for="LastName" class="c-err"></span>
                </div>
            </div>

            <!-- Email -->
            <div class="c-field">
                <div class="c-label-row">
                    <label class="c-label" asp-for="Email">Email Address</label>
                </div>
                <div class="c-input-wrap">
                    <i class="fas fa-envelope c-ico"></i>
                    <input asp-for="Email" class="c-input" placeholder="juan@example.com"
                           autocomplete="email" type="email" />
                </div>
                <span asp-validation-for="Email" class="c-err"></span>
            </div>

            <!-- Phone -->
            <div class="c-field">
                <div class="c-label-row">
                    <label class="c-label" asp-for="PhoneNumber">Phone Number</label>
                </div>
                <div class="c-input-wrap">
                    <i class="fas fa-phone c-ico"></i>
                    <input asp-for="PhoneNumber" class="c-input" placeholder="+63 912 345 6789"
                           autocomplete="tel" type="tel" />
                </div>
                <span asp-validation-for="PhoneNumber" class="c-err"></span>
            </div>

            <!-- Password row -->
            <div class="c-row">
                <div class="c-field">
                    <div class="c-label-row">
                        <label class="c-label" asp-for="Password">Password</label>
                    </div>
                    <div class="c-input-wrap">
                        <i class="fas fa-lock c-ico"></i>
                        <input asp-for="Password" type="password" id="regPwd"
                               class="c-input c-has-eye" placeholder="Min. 6 characters"
                               autocomplete="new-password" />
                        <button type="button" class="c-eye" id="regEyeBtn" aria-label="Toggle password">
                            <i class="fas fa-eye" id="regEyeIcon"></i>
                        </button>
                    </div>
                    <div class="c-strength">
                        <div class="c-strength-track">
                            <div class="c-strength-fill" id="strengthFill" data-level="0"></div>
                        </div>
                        <span class="c-strength-hint" id="strengthHint">Enter a password</span>
                    </div>
                    <span asp-validation-for="Password" class="c-err"></span>
                </div>
                <div class="c-field">
                    <div class="c-label-row">
                        <label class="c-label" asp-for="ConfirmPassword">Confirm Password</label>
                    </div>
                    <div class="c-input-wrap">
                        <i class="fas fa-lock c-ico"></i>
                        <input asp-for="ConfirmPassword" type="password" id="regPwdConfirm"
                               class="c-input c-has-eye" placeholder="Repeat password"
                               autocomplete="new-password" />
                        <button type="button" class="c-eye" id="regEye2Btn" aria-label="Toggle confirm password">
                            <i class="fas fa-eye" id="regEye2Icon"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="c-err"></span>
                </div>
            </div>

            <button type="submit" class="c-btn">
                <i class="fas fa-user-plus me-2"></i>Create My Account
            </button>
        </form>

        <div class="c-divider">or</div>
        <p class="c-footer-text">Already have an account? <a href="/Customer/Login">Sign in here</a></p>

    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            /* ── Eye toggles ── */
            function eyeToggle(inputId, btnId, iconId) {
                var inp = document.getElementById(inputId);
                var btn = document.getElementById(btnId);
                var ico = document.getElementById(iconId);
                if (!btn) return;
                btn.addEventListener('click', function () {
                    var show = inp.type === 'password';
                    inp.type = show ? 'text' : 'password';
                    ico.className = show ? 'fas fa-eye-slash' : 'fas fa-eye';
                });
            }
            eyeToggle('regPwd',        'regEyeBtn',  'regEyeIcon');
            eyeToggle('regPwdConfirm', 'regEye2Btn', 'regEye2Icon');

            /* ── Password strength ── */
            var pwdInput  = document.getElementById('regPwd');
            var fill      = document.getElementById('strengthFill');
            var hint      = document.getElementById('strengthHint');
            var hints     = ['', 'Too short', 'Weak', 'Fair', 'Good', 'Strong!'];
            if (pwdInput && fill) {
                pwdInput.addEventListener('input', function () {
                    var v = pwdInput.value;
                    var score = 0;
                    if (v.length >= 6)  score++;
                    if (v.length >= 10) score++;
                    if (/[A-Z]/.test(v)) score++;
                    if (/[0-9]/.test(v)) score++;
                    if (/[^A-Za-z0-9]/.test(v)) score++;
                    fill.setAttribute('data-level', v.length ? score : 0);
                    hint.textContent = v.length ? hints[score] : 'Enter a password';
                });
            }

            /* ── Confirm password match check ── */
            var confInput = document.getElementById('regPwdConfirm');
            if (confInput && pwdInput) {
                confInput.addEventListener('blur', function () {
                    confInput.classList.remove('valid', 'invalid');
                    if (confInput.value) {
                        confInput.classList.add(confInput.value === pwdInput.value ? 'valid' : 'invalid');
                    }
                });
            }

            /* ── Live blur validation on text fields ── */
            document.querySelectorAll('.c-input:not([type="password"])').forEach(function (el) {
                el.addEventListener('blur', function () {
                    el.classList.remove('valid', 'invalid');
                    if (el.value.trim()) el.classList.add(el.checkValidity() ? 'valid' : 'invalid');
                });
            });
        })();
    </script>
}

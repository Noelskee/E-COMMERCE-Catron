@using Catron_Computer_Technology_PROEL4W_FINALS_.Models.ViewModels
@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <div class="auth-header text-center mb-4">
            <div class="auth-logo mx-auto mb-3"><i class="fas fa-key"></i></div>
            <h4 class="fw-bold">Forgot Password?</h4>
            <p class="text-muted">Enter your email to receive a reset link.</p>
        </div>
        <form asp-action="ForgotPassword" method="post">
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-semibold small">Email Address</label>
                <div class="input-group">
                    <span class="input-group-text bg-light border-end-0"><i class="fas fa-envelope text-muted"></i></span>
                    <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="your@email.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100 fw-semibold">
                <i class="fas fa-paper-plane me-2"></i>Send Reset Link
            </button>
        </form>
        <div class="text-center mt-3">
            <a href="/Customer/Login" class="text-muted small text-decoration-none"><i class="fas fa-arrow-left me-1"></i>Back to Login</a>
        </div>
    </div>
</div>

@using Catron_Computer_Technology_PROEL4W_FINALS_.Models.ViewModels
@model CheckoutViewModel
@{
    ViewData["Title"] = "Checkout";
}

<div class="container py-4">
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="/Customer/Index">Home</a></li>
            <li class="breadcrumb-item"><a href="/Customer/Cart">Cart</a></li>
            <li class="breadcrumb-item active">Checkout</li>
        </ol>
    </nav>
    <h4 class="fw-bold mb-4" style="font-family:'Outfit',sans-serif"><i class="fas fa-credit-card me-2 text-success"></i>Checkout</h4>

    <div class="row g-4">
        <!-- Left -->
        <div class="col-lg-7">
            <form asp-action="PlaceOrder" method="post" id="checkoutForm">

                @if (Model.SavedAddresses.Any())
                {
                    <div class="card border-0 shadow-sm rounded-4 mb-4">
                        <div class="card-body p-4">
                            <h6 class="fw-bold mb-3"><i class="fas fa-bookmark me-2 text-success"></i>Saved Addresses</h6>
                            @foreach (var addr in Model.SavedAddresses)
                            {
                                <div class="form-check address-select-card p-3 rounded-3 border mb-2 @(addr.IsDefault ? "border-success" : "")">
                                    <input class="form-check-input" type="radio" name="savedAddress" value="@addr.Id"
                                           onchange="fillAddress('@addr.FullName.Replace("'", "\\'")', '@addr.Address.Replace("'", "\\'")', '@addr.PhoneNumber')"
                                           @(addr.IsDefault ? "checked" : "") />
                                    <label class="form-check-label w-100">
                                        <strong>@addr.FullName</strong> @if (addr.IsDefault) {
                                        <span class="badge bg-success ms-1">Default</span>
                                    }
                                    <div class="small text-muted">@addr.Address</div>
                                    <div class="small text-muted">@addr.PhoneNumber</div>
                                </label>
                            </div>
                        }
                    </div>
                </div>
                                }

                <!-- Shipping -->
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3"><i class="fas fa-map-marker-alt me-2 text-danger"></i>Shipping Address</h6>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold small">Full Name</label>
                                <input asp-for="ShippingFullName" class="form-control" id="shipName" placeholder="Juan dela Cruz" />
                                <span asp-validation-for="ShippingFullName" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold small">Complete Address</label>
                                <textarea asp-for="ShippingAddress" class="form-control" rows="3" id="shipAddr" placeholder="House/Unit No., Street, Barangay, City, Province"></textarea>
                                <span asp-validation-for="ShippingAddress" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold small">Phone Number</label>
                                <input asp-for="ShippingPhone" class="form-control" id="shipPhone" placeholder="+63 912 345 6789" />
                                <span asp-validation-for="ShippingPhone" class="text-danger small"></span>
                            </div>
                            <div class="col-12">
                                <div style="display:flex;align-items:flex-start;gap:.6rem;padding:.85rem 1rem;background:rgba(22,163,74,.05);border:1.5px solid rgba(22,163,74,.18);border-radius:10px;cursor:pointer" onclick="document.getElementById('saveAddrChk').click()">
                                    <input type="checkbox" name="SaveAddress" id="saveAddrChk" value="true"
                                           style="width:16px;height:16px;accent-color:#16a34a;flex-shrink:0;margin-top:.1rem;cursor:pointer" />
                                    <div>
                                        <div style="font-size:.87rem;font-weight:700;color:#0f172a">Save this address to my account</div>
                                        <div style="font-size:.77rem;color:#64748b;margin-top:.1rem">Quickly select it on future orders from My Addresses</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-4">
                        <h6 class="fw-bold mb-3"><i class="fas fa-wallet me-2 text-success"></i>Payment Method</h6>
                        <div class="row g-2">
                            <div class="col-6 col-md-3">
                                <label class="payment-method-card w-100" data-method="Cash">
                                    <input type="radio" name="paymentMethod" value="Cash" class="d-none" checked />
                                    <div class="pm-icon"><i class="fas fa-money-bill-wave text-success"></i></div>
                                    <div class="pm-label">Cash</div>
                                    <div class="pm-sub">On Delivery</div>
                                </label>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="payment-method-card w-100" data-method="DebitCard">
                                    <input type="radio" name="paymentMethod" value="DebitCard" class="d-none" />
                                    <div class="pm-icon"><i class="fas fa-credit-card text-primary"></i></div>
                                    <div class="pm-label">Debit Card</div>
                                    <div class="pm-sub">Visa / Mastercard</div>
                                </label>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="payment-method-card w-100" data-method="CreditCard">
                                    <input type="radio" name="paymentMethod" value="CreditCard" class="d-none" />
                                    <div class="pm-icon"><i class="fas fa-credit-card text-warning"></i></div>
                                    <div class="pm-label">Credit Card</div>
                                    <div class="pm-sub">Any Bank</div>
                                </label>
                            </div>
                            <div class="col-6 col-md-3">
                                <label class="payment-method-card w-100" data-method="GCash">
                                    <input type="radio" name="paymentMethod" value="GCash" class="d-none" />
                                    <div class="pm-icon"><i class="fas fa-mobile-alt" style="color:#0070f0"></i></div>
                                    <div class="pm-label">GCash</div>
                                    <div class="pm-sub">QR / Transfer</div>
                                </label>
                            </div>
                        </div>

                        <!-- GCash info box (shows on selection) -->
                        <div id="gcash-info" class="mt-3" style="display:none">
                            <div class="alert border-0 rounded-3" style="background:rgba(0,112,240,.08);border:1px solid rgba(0,112,240,.2)!important">
                                <i class="fas fa-info-circle me-2" style="color:#0070f0"></i>
                                <strong>After placing your order,</strong> you will be shown a GCash QR code and the Catron GCash number to send payment to. Please screenshot the reference number.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Cart summary for checkout -->
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-body p-0">
                        <div class="p-4 border-bottom d-flex justify-content-between align-items-center">
                            <h6 class="fw-bold mb-0"><i class="fas fa-shopping-bag me-2 text-success"></i>Order Items</h6>
                            <span class="badge" style="background:var(--g100);color:var(--g700)">@@Model.CartItems.Count item(s)</span>
                        </div>
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex align-items-center gap-3 px-4 py-3 border-bottom">
                                <div style="width:52px;height:52px;flex-shrink:0;border-radius:10px;background:var(--g50);overflow:hidden;display:flex;align-items:center;justify-content:center">
                                    @if (!string.IsNullOrEmpty(item.Product.ImageUrl))
                                    {
                                        <img src="@item.Product.ImageUrl" style="width:100%;height:100%;object-fit:contain;padding:4px" />
                                    }
                                    else
                                    {

                                        <i class="@(item.Product.Category?.IconClass ?? "fas fa-box") text-success"></i>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <div class="fw-semibold small">@item.Product.Name</div>
                                    <div class="text-muted" style="font-size:.75rem">@item.Product.Brand</div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold small" style="color:var(--g700)">₱@item.Subtotal.ToString("N0")</div>
                                    <div class="text-muted" style="font-size:.72rem">×@item.Quantity</div>
                                </div>
                            </div>
                        }
                        <div class="px-4 py-3 d-flex justify-content-between align-items-center">
                            <span class="fw-bold">Total</span>
                            <span class="fw-bold fs-5" style="color:var(--g700)">₱@Model.TotalAmount.ToString("N0")</span>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-brand w-100 btn-lg fw-bold py-3" style="font-family:'Outfit',sans-serif;font-size:1.05rem">
                    <i class="fas fa-lock me-2"></i>Place Order — ₱@Model.TotalAmount.ToString("N0")
                </button>
                <p class="text-center text-muted small mt-2"><i class="fas fa-shield-alt text-success me-1"></i>Your order is protected by Catron's secure checkout</p>
            </form>
        </div>

        <!-- Right: live summary -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top:90px">
                <div class="card-body p-0">
                    <div class="p-4" style="background:linear-gradient(135deg,var(--g800),var(--g900));border-radius:var(--radius-lg) var(--radius-lg) 0 0">
                        <h6 class="fw-bold mb-0 text-white"><i class="fas fa-receipt me-2"></i>Order Summary</h6>
                    </div>
                    <div class="p-4">
                        @foreach (var item in Model.CartItems)
                        {
                            <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="badge rounded-pill fw-bold" style="background:var(--g100);color:var(--g700)">×@item.Quantity</span>
                                    <span class="small fw-semibold">@item.Product.Name</span>
                                </div>
                                <span class="small fw-bold">₱@item.Subtotal.ToString("N0")</span>
                            </div>
                        }
                        <div class="d-flex justify-content-between mt-3 mb-1">
                            <span class="text-muted small">Subtotal</span>
                            <span class="small">₱@Model.TotalAmount.ToString("N0")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted small">Shipping</span>
                            <span class="small text-success fw-bold">FREE</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between fw-bold fs-5">
                            <span>Total</span>
                            <span style="color:var(--g700)">₱@Model.TotalAmount.ToString("N0")</span>
                        </div>
                        <div class="mt-4 p-3 rounded-3" style="background:var(--g50)">
                            <div class="d-flex align-items-center gap-2 mb-1"><i class="fas fa-shield-alt text-success small"></i><span class="small fw-semibold">100% Secure Payment</span></div>
                            <div class="d-flex align-items-center gap-2 mb-1"><i class="fas fa-truck text-primary small"></i><span class="small fw-semibold">Free Delivery</span></div>
                            <div class="d-flex align-items-center gap-2"><i class="fas fa-undo text-warning small"></i><span class="small fw-semibold">7-Day Returns</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function fillAddress(name, addr, phone) {
            document.getElementById('shipName').value = name;
            document.getElementById('shipAddr').value = addr;
            document.getElementById('shipPhone').value = phone;
        }

        // Payment method cards
        const cards = document.querySelectorAll('.payment-method-card');
        cards.forEach(card => {
            // Mark default selected
            if (card.querySelector('input:checked')) card.classList.add('selected');
            card.addEventListener('click', function() {
                cards.forEach(c => c.classList.remove('selected'));
                this.classList.add('selected');
                this.querySelector('input').checked = true;
                const method = this.dataset.method;
                document.getElementById('gcash-info').style.display = method === 'GCash' ? 'block' : 'none';
            });
        });
    </script>
}


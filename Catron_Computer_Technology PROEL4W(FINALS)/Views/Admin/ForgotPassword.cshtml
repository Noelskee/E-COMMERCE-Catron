@using Catron_Computer_Technology_PROEL4W_FINALS_.Models.ViewModels
@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password"; Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password – Admin | Catron</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet" />
</head>
<body style="background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);min-height:100vh;display:flex;align-items:center;justify-content:center;">
    <div style="width:100%;max-width:420px;padding:1rem;">
        <div class="text-center mb-4">
            <div style="width:65px;height:65px;background:linear-gradient(135deg,#e94560,#c23152);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                <i class="fas fa-key text-white" style="font-size:1.6rem;"></i>
            </div>
            <h4 class="text-white fw-bold mb-1">Forgot Password</h4>
            <p class="text-white-50 small">Enter your admin email to receive a reset link.</p>
        </div>
        <div style="background:rgba(255,255,255,.05);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:2rem;">
            <form asp-action="ForgotPassword" asp-controller="Admin" method="post">
                <div class="mb-4">
                    <label asp-for="Email" class="form-label text-white-75 fw-semibold small">Email Address</label>
                    <input asp-for="Email" class="form-control" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.15);color:#fff;" placeholder="admin@catrontech.ph" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn w-100 fw-bold py-2" style="background:linear-gradient(135deg,#e94560,#c23152);border:none;color:#fff;border-radius:10px;">
                    <i class="fas fa-paper-plane me-2"></i>Send Reset Link
                </button>
            </form>
            <div class="text-center mt-3">
                <a href="/Admin/Login" class="text-white-50 small text-decoration-none">
                    <i class="fas fa-arrow-left me-1"></i>Back to Login
                </a>
            </div>
        </div>
    </div>
</body>
</html>

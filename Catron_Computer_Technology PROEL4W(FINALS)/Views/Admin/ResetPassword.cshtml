@using Catron_Computer_Technology_PROEL4W_FINALS_.Models.ViewModels
@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password"; Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password – Admin | Catron</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <link href="/css/site.css" rel="stylesheet" />
</head>
<body style="background:linear-gradient(135deg,#1a1a2e,#16213e,#0f3460);min-height:100vh;display:flex;align-items:center;justify-content:center;">
    <div style="width:100%;max-width:420px;padding:1rem;">
        <div class="text-center mb-4">
            <div style="width:65px;height:65px;background:linear-gradient(135deg,#e94560,#c23152);border-radius:16px;display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;">
                <i class="fas fa-lock text-white" style="font-size:1.6rem;"></i>
            </div>
            <h4 class="text-white fw-bold mb-1">Reset Password</h4>
            <p class="text-white-50 small">Enter your new admin password.</p>
        </div>
        <div style="background:rgba(255,255,255,.05);backdrop-filter:blur(10px);border:1px solid rgba(255,255,255,.1);border-radius:20px;padding:2rem;">
            <form asp-action="ResetPassword" asp-controller="Admin" method="post">
                <input type="hidden" asp-for="Token" />
                <input type="hidden" asp-for="Email" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded-3 small mb-3"></div>
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label text-white-75 fw-semibold small">New Password</label>
                    <input asp-for="NewPassword" type="password" class="form-control" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.15);color:#fff;" placeholder="Min. 6 chars" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label text-white-75 fw-semibold small">Confirm Password</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-control" style="background:rgba(255,255,255,.08);border-color:rgba(255,255,255,.15);color:#fff;" placeholder="Repeat password" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <button type="submit" class="btn w-100 fw-bold py-2" style="background:linear-gradient(135deg,#e94560,#c23152);border:none;color:#fff;border-radius:10px;">
                    <i class="fas fa-save me-2"></i>Reset Password
                </button>
            </form>
        </div>
    </div>
</body>
</html>

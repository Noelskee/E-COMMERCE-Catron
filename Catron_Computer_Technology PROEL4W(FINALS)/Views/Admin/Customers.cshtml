@model IEnumerable<Customer>
@{
    ViewData["Title"] = "Customers"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 style="font-family:'Outfit',sans-serif;font-weight:800;color:var(--txt);margin:0">Customers</h5>
        <small style="color:var(--muted)">@Model.Count() registered · Total spent: ₱@Model.SelectMany(c => c.Orders).Sum(o => o.TotalAmount).ToString("N0")</small>
    </div>
    <div class="live-dot" title="Live"></div>
</div>

<div class="toolbar mb-4">
    <div class="search-box flex-grow-1">
        <i class="fas fa-search"></i>
        <input type="text" id="custSearch" placeholder="Search by name or email…" oninput="filterCust()" />
    </div>
</div>

<div class="admin-card">
    <table class="data-table" id="custTable">
        <thead>
            <tr><th>Customer</th><th>Phone</th><th>Orders</th><th>Total Spent</th><th>Joined</th><th>Status</th><th>Action</th></tr>
        </thead>
        <tbody>
            @foreach (var c in Model)
            {
                <tr data-search="@c.FullName @c.Email @c.PhoneNumber">
                    <td>
                        <div class="d-flex align-items-center gap-3">
                            <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,var(--g500),var(--g700));
                                            display:flex;align-items:center;justify-content:center;color:#fff;font-weight:800;font-size:.75rem;flex-shrink:0">
                                @c.FirstName[0]@c.LastName[0]
                            </div>
                            <div>
                                <div style="font-weight:700;color:var(--txt);font-size:.87rem">@c.FullName</div>
                                <div style="font-size:.72rem;color:var(--muted)">@c.Email</div>
                            </div>
                        </div>
                    </td>
                    <td style="color:var(--txt2);font-size:.83rem">@(c.PhoneNumber ?? "—")</td>
                    <td><span class="badge badge-blue">@c.Orders.Count order(s)</span></td>
                    <td style="font-weight:700;color:var(--g300);font-size:.87rem">₱@c.Orders.Sum(o => o.TotalAmount).ToString("N0")</td>
                    <td style="color:var(--muted);font-size:.78rem">@c.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td><span class="badge @(c.IsActive ? "badge-green" : "badge-red")">@(c.IsActive ? "Active" : "Inactive")</span></td>
                    <td><a href="/Admin/CustomerDetail/@c.Id" class="btn-outline-sm"><i class="fas fa-eye"></i>View</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        function filterCust() {
            const q = document.getElementById('custSearch').value.toLowerCase();
            document.querySelectorAll('#custTable tbody tr').forEach(row => {
                row.style.display = (row.dataset.search || row.textContent).toLowerCase().includes(q) ? '' : 'none';
            });
        }
    </script>
}

@model IEnumerable<ReturnRequest>
@{
    ViewData["Title"] = "Returns & Refunds"; Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@functions {
    string RC(ReturnStatus s) => s switch
    {
        ReturnStatus.Pending => "amber",
        ReturnStatus.Approved => "green",
        ReturnStatus.Rejected => "red",
        ReturnStatus.Completed => "blue",
        _ => "muted"
    };
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 style="font-family:'Outfit',sans-serif;font-weight:800;color:var(--txt);margin:0">Returns &amp; Refunds</h5>
        <small style="color:var(--muted)">@Model.Count(r => r.Status == ReturnStatus.Pending) pending · @Model.Count() total</small>
    </div>
</div>

<div class="admin-card">
    @if (!Model.Any())
    {
        <div class="empty-state"><i class="fas fa-undo"></i><p>No return requests.</p></div>
    }
    else
    {
        <table class="data-table">
            <thead><tr><th>Customer</th><th>Order #</th><th>Reason</th><th>Date</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
                @foreach (var r in Model.OrderByDescending(r => r.RequestedAt))
                {
                    <tr>
                        <td>
                            <div style="font-weight:700;color:var(--txt);font-size:.86rem">@r.Customer?.FullName</div>
                            <div style="font-size:.73rem;color:var(--muted)">@r.Customer?.Email</div>
                        </td>
                        <td><a href="/Admin/OrderDetail/@r.OrderId" class="tbl-link">#@r.Order?.OrderNumber</a></td>
                        <td style="color:var(--txt2);font-size:.83rem;max-width:200px">@r.Reason</td>
                        <td style="color:var(--muted);font-size:.78rem">@r.RequestedAt.ToString("MMM dd, yyyy")</td>
                        <td><span class="badge badge-@RC(r.Status)">@r.Status</span></td>
                        <td>
                            @if (r.Status == ReturnStatus.Pending)
                            {
                                <div class="d-flex gap-1">
                                    <form asp-action="ApproveReturn" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit" class="btn-success-sm"><i class="fas fa-check"></i>Approve</button>
                                    </form>
                                    <form asp-action="RejectReturn" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@r.Id" />
                                        <button type="submit" class="btn-danger-sm"><i class="fas fa-times"></i>Reject</button>
                                    </form>
                                </div>
                            }
                            else
                            {

                                <span style="color:var(--muted);font-size:.82rem">@r.Status</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
